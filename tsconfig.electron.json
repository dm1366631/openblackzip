{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noImplicitAny": false
  },
  "include": [
    "electron/**/*.ts"
  ]
}